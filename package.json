{
  "name": "proxbot",
  "version": "0.2.0-rc.1",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "description": "High-fidelity iOS application traffic capture and analysis",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run check:frontend && vite build",
    "build:provider": "./scripts/build-provider-sidecar.sh",
    "build:proxy": "./scripts/build-proxy-sidecar.sh",
    "build:sidecars": "bun run notices:generate && bun run build:provider && bun run build:proxy && bun run mcp:compile",
    "preview": "vite preview",
    "test": "bun run test:all",
    "test:frontend": "vitest run",
    "test:all": "bun run test:frontend && bun run mcp:test",
    "test:watch": "vitest",
    "check": "bun run check:all",
    "check:frontend": "tsc --noEmit",
    "check:all": "bun run check:frontend && bun run mcp:check",
    "mcp:start": "bun run --cwd apps/mcp-server start",
    "mcp:check": "bun run --cwd apps/mcp-server check",
    "mcp:test": "bun run --cwd apps/mcp-server test",
    "mcp:compile": "bun run --cwd apps/mcp-server compile:macos",
    "mcp:hardware-smoke": "bun run --cwd apps/mcp-server hardware-smoke",
    "hygiene": "bun scripts/repository-hygiene.mjs",
    "research:verify": "bun scripts/research/verify-ch-capability-artifacts.mjs",
    "version:check": "bun scripts/verify-version-parity.mjs",
    "notices:generate": "python3 scripts/generate-third-party-notices.py",
    "tauri": "tauri",
    "tauri:build": "bun run build:sidecars && tauri build"
  },
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-virtual": "3.14.8",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "qrcode": "1.5.4",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
