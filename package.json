{
  "name": "proxbot",
  "version": "0.1.0",
  "description": "High-fidelity iOS application traffic capture and analysis",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:provider": "./scripts/build-provider-sidecar.sh",
